FROM python:3.12-slim-bookworm

WORKDIR /app
COPY pyproject.toml /app/pyproject.toml
COPY src /app/src
COPY data /app/data

RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir .

EXPOSE 8501
CMD ["streamlit", "run", "src/rag_chatbot/ui/app.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
