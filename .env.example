# API security
RAG_API_KEY=dev-secret

# LLM options
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenRouter options (set LLM_PROVIDER=openrouter to use)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=rag-chatbot-portfolio

# Vector DB options
CHROMA_MODE=http
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=documents
CHROMA_PERSIST_DIR=./chroma_data

# Embedding + reranking models (fully local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval defaults
TOP_K=5
USE_HYBRID=true
USE_RERANK=true

# Logging
QUERY_LOG_PATH=logs/query_log.jsonl
